# Discord
BOT_TOKEN="..."

# MongoDB
MONGO="mongodb://..."
MONGO_DB="pluralbuddy-canary"
WEBSITE_DB="canary-pluralbuddy-app"

# Frontend location. Can be left blank if you aren't using frontend dependent things (ie. pb;s import)
APP_HOST="http://localhost:3000"

# used if you want nepotism for the server configuration settings
# just put your user id
SRV_CFG_TEST_USER_ID="..."

# Backend API
# You really only need this if you want to keep a sync between PluralBuddy's website and the bot process.
# Optimally use: openssl rand -base64 32
API_KEY=""

# Version Control
BRANCH="canary"

# Google Cloud
# Really only needed for uploading attachments
GCP_BUCKET="..."
GCP_TOKEN="..."

# Proxying
LINK_SCRAPER_API="https://pb-link-scraper.giftedl.deno.net/api/meta"