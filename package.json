{
	"name": "pluralbuddy",
	"devDependencies": {
		"@biomejs/biome": "2.0.6"
	},
	"private": true,
	"scripts": {
		"bot": "cd packages/bot && bun run bot",
		"bot:watch": "cd packages/bot && bun run bot:watch",
		"support:bot": "cd packages/support-bot-module && bun run bot",
		"docs:dev": "cd apps/docs && bun run dev",
		"docs:openapi": "cd packages/plurography && bun run src/openapi && cd ../../apps/docs && rm -rf content/docs/en/pluralbuddy/api && bun run scripts/generate-docs.ts"
	},
	"workspaces": ["packages/*", "apps/*"],
	"dependencies": {
		"posthog-node": "^5.24.17"
	}
}